# ── Read-only GitHub token (safe to commit to Vercel env vars) ──────────────
# Create at: https://github.com/settings/tokens?type=beta
# Permissions needed: Repository access → your data repo → Contents: Read-only
# This token is baked into the built JS. It CANNOT write, so it's safe to expose.

REACT_APP_RO_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
REACT_APP_RO_REPO=youruser/your-library-data-repo

# ── DO NOT put your read-write token here ───────────────────────────────────
# The write token is entered only once in the app's Sync Settings page
# and stored only in your browser's localStorage. Never lives in code.
